# ─── App ─────────────────────────────────────────────────────────────────────
APP_NAME="Algo Kaisen"
APP_VERSION="0.1.0"
DEBUG=false

# ─── Database (PostgreSQL / Supabase) ────────────────────────────────────────
# Format: postgresql+asyncpg://user:password@host:port/dbname
# For Supabase (Session pooler — port 5432):
#   DATABASE_URL=postgresql+asyncpg://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
# For Supabase (Transaction pooler — port 6543, use for serverless):
#   DATABASE_URL=postgresql+asyncpg://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=

# ─── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Supabase Storage ────────────────────────────────────────────────────────
# Bucket name where heavy equity_curve arrays are stored as JSON files
STORAGE_BUCKET=backtest-results

# ─── Binance ─────────────────────────────────────────────────────────────────
BINANCE_USE_TESTNET_FOR_HISTORY=false
BINANCE_MAINNET_BASE_URL=https://api.binance.com
BINANCE_TESTNET_BASE_URL=https://testnet.binance.vision

# ─── Rate Limits (per HLD §5.2) ──────────────────────────────────────────────
BACKTEST_RATE_LIMIT=10
BACKTEST_RATE_LIMIT_WINDOW=60

# ─── Historical Data LRU Cache ───────────────────────────────────────────────
HISTORICAL_CACHE_TTL=3600
HISTORICAL_CACHE_MAXSIZE=256

# ─── Thread Pool ─────────────────────────────────────────────────────────────
BACKTEST_THREAD_POOL_SIZE=4

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]